{
  "name": "eagle-oppai-tagger",
  "version": "0.1.0",
  "private": true,
  "description": "Eagle plugin: ONNX-based image tagging with OppaiOracle",
  "scripts": {
    "test": "node src/phase2-test.js && node src/phase3-test.js && node src/phase4-test.js && node src/phase5-test.js",
    "test:preprocess": "node src/verify.js",
    "check": "node -e \"const fs=require('fs'),cp=require('child_process');(function w(d){for(const e of fs.readdirSync(d,{withFileTypes:true})){const p=d+'/'+e.name;if(e.isDirectory())w(p);else if(p.endsWith('.js')){cp.execSync('node --check \\\"'+p+'\\\"',{stdio:'inherit'})}}})('src')\"",
    "profile": "node scripts/profile.js"
  },
  "dependencies": {
    "jimp": "0.22.12",
    "onnxruntime-node": "1.27.0"
  }
}
